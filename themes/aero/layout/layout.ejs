<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= config.title %></title>
    <%- css('css/style.css') %>
    <% if (theme.favicon.enable) { %>
        <% if (theme.favicon.icon) { %>
            <link rel="icon" href="<%= url_for(theme.favicon.icon) %>">
        <% } %>
    <% } %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@4.9.1/fonts/remixicon.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.7.0/styles/atom-one-light.min.css">

    <!-- Intro sequence styles (after main CSS so they win priority) -->
    <style>
      .camera-rig {
        position: fixed; top: 0; left: 0;
        width: 100vw; height: 100vh;
        z-index: 0; pointer-events: none;
        overflow: hidden;
      }
      .camera-rig .bg-frame {
        width: 100%; height: 100%;
        animation: cameraZoom 3s cubic-bezier(0.12, 0.0, 0.1, 1.0) forwards;
      }
      .camera-rig .bg-frame iframe {
        position: absolute; top: 0; left: 0;
        width: 100vw; height: 100vh;
        border: none; pointer-events: none;
      }
      @keyframes cameraZoom {
        0%   { transform: scale(2.5); filter: blur(12px) brightness(0.3); }
        30%  { filter: blur(8px) brightness(0.5); }
        60%  { filter: blur(3px) brightness(0.8); }
        100% { transform: scale(1.0); filter: blur(0px) brightness(1.0); }
      }

      /* Overlay flash at the end of camera move */
      .camera-flash {
        position: fixed; top: 0; left: 0;
        width: 100vw; height: 100vh;
        z-index: 1; pointer-events: none;
        background: white;
        opacity: 0;
        animation: flashWhite 0.4s ease-out 2.8s forwards;
      }
      @keyframes flashWhite {
        0%   { opacity: 0; }
        50%  { opacity: 0.6; }
        100% { opacity: 0; }
      }

      .intro-item { opacity: 0; }
      .intro-item.revealed {
        animation: blinkIn 0.4s ease-out forwards;
      }
      @keyframes blinkIn {
        0%   { opacity: 0;   filter: brightness(3) blur(2px); }
        30%  { opacity: 0.7; filter: brightness(1.5) blur(0px); }
        55%  { opacity: 0.3; filter: brightness(0.8); }
        100% { opacity: 1;   filter: brightness(1); }
      }

      .taskbar.intro-item {
        opacity: 0;
        transform: translateY(100%);
      }
      .taskbar.intro-item.revealed {
        animation: taskbarIn 0.5s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
      }
      @keyframes taskbarIn {
        0%   { opacity: 0;   transform: translateY(100%); }
        100% { opacity: 1;   transform: translateY(0);    }
      }

      /* Skip intro if cookie set (returning visitor) */
      .no-intro .intro-item { opacity: 1; }
      .no-intro .taskbar.intro-item { opacity: 1; transform: none; }
      .no-intro .camera-rig .bg-frame { animation: none; transform: scale(1); filter: none; }
      .no-intro .camera-flash { display: none; }
    </style>
</head>

<body class="has-taskbar">
    <!-- Camera rig: 3D perspective animation wrapping the galaxy iframe -->
    <div class="camera-rig">
        <div class="bg-frame">
            <iframe src="/galaxy-bg/" allow="autoplay" title="background"></iframe>
        </div>
    </div>
    <div class="camera-flash"></div>

    <div class="container">
        <!-- Desktop Icons -->
        <div class="desktop-icons intro-item" data-delay="3200">
            <a href="/" class="desktop-icon"><img src="/image/icon/vista_messenger.jpg" alt="home"><span class="icon-label">我的首页</span></a>
            <a href="/archives" class="desktop-icon"><img src="/image/icon/vista_book_1.jpg" alt="archives"><span class="icon-label">时间轴</span></a>
            <a href="/categories/thoughts" class="desktop-icon"><img src="/image/icon/vista_messenger.jpg" alt="thoughts"><span class="icon-label">想法</span></a>
            <a href="/categories/learning" class="desktop-icon"><img src="/image/icon/vista_book_1.jpg" alt="learning"><span class="icon-label">学习</span></a>
            <a href="/spending" class="desktop-icon"><img src="/image/icon/vista_photo_gallery.jpg" alt="spending"><span class="icon-label">消费</span></a>
            <a href="/about" class="desktop-icon"><img src="/image/icon/vista_pc_1.jpg" alt="about"><span class="icon-label">关于</span></a>
        </div>

        <!-- Title Window -->
        <div class="header draggable-element intro-item" id="pjax-header" data-delay="3050">
            <header><p class="blog-title"><%= config.title %></p></header>
            <nav>
                <ul class="nav-links">
                    <li><a href="/" class="<%= is_home() ? 'active' : '' %>"><span class="nav-text"><img src="/image/icon/vista_messenger.jpg" alt="home" class="icon"><span>Home</span></span></a></li>
                    <li><a href="/categories/thoughts"><span class="nav-text"><img src="/image/icon/vista_messenger.jpg" alt="thoughts" class="icon">想法</span></a></li>
                    <li><a href="/categories/learning"><span class="nav-text"><img src="/image/icon/vista_book_1.jpg" alt="learning" class="icon">学习</span></a></li>
                    <li><a href="/spending"><span class="nav-text"><img src="/image/icon/vista_photo_gallery.jpg" alt="spending" class="icon">消费</span></a></li>
                    <li><a href="/archives"><span class="nav-text"><img src="/image/icon/vista_book_1.jpg" alt="posts" class="icon">时间轴</span></a></li>
                    <li><a href="/about"><span class="nav-text"><img src="/image/icon/vista_pc_1.jpg" alt="about" class="icon">关于</span></a></li>
                </ul>
            </nav>
        </div>

        <div class="button mobile-menu-btn intro-item" id="mobile-menu-btn" data-delay="3350">
            <span class="menu-icon ri-menu-fill"></span>
        </div>

        <div class="main-layout intro-item" data-delay="3200">
            <aside id="sidebar">
                <%- partial('_partial/widget') %>
            </aside>
            <main id="pjax-container">
                <%- body %>
            </main>
            <div class="sidebar-mask" id="sidebar-mask"></div>
        </div>
    </div>

    <!-- Taskbar -->
    <div class="taskbar intro-item" data-delay="3500">
        <a href="/" class="taskbar-item <%= is_home() ? 'active' : '' %>"><img src="/image/icon/vista_messenger.jpg" alt="home"> Home</a>
        <a href="/categories/thoughts" class="taskbar-item"><img src="/image/icon/vista_messenger.jpg" alt="thoughts"> 想法</a>
        <a href="/categories/learning" class="taskbar-item"><img src="/image/icon/vista_book_1.jpg" alt="learning"> 学习</a>
        <a href="/spending" class="taskbar-item"><img src="/image/icon/vista_photo_gallery.jpg" alt="spending"> 消费</a>
        <a href="/archives" class="taskbar-item <%= is_archive() || is_current('archives') ? 'active' : '' %>"><img src="/image/icon/vista_book_1.jpg" alt="archives"> 时间轴</a>
        <a href="/about" class="taskbar-item <%= is_current('about') ? 'active' : '' %>"><img src="/image/icon/vista_pc_1.jpg" alt="about"> 关于</a>
        <div class="taskbar-tray">
            <span style="margin-right:12px;font-size:11px;color:#666;">&copy; <%= date(new Date(), 'YYYY') %> <%= config.author %></span>
            <span class="clock" id="taskbar-clock">--:--</span>
        </div>
    </div>

    <script src="/js/responsive.js"></script>
    <script src="/js/music.js"></script>
    <script src="/js/desktop.js"></script>
    <script src="/js/image-viewer.js"></script>

    <!-- Intro sequence controller -->
    <script>
(function() {
  // Check cookie: skip intro for returning visitors within 10 minutes
  var skipIntro = document.cookie.indexOf('intro_done=1') !== -1;
  if (skipIntro) {
    document.body.classList.add('no-intro');
    document.body.classList.remove('has-taskbar');
  }

  var items = document.querySelectorAll('.intro-item');
  items.forEach(function(el) {
    var delay = parseInt(el.getAttribute('data-delay')) || 3000;
    // If skipping intro, reveal immediately
    if (skipIntro) {
      el.classList.add('revealed');
    } else {
      setTimeout(function() {
        el.classList.add('revealed');
      }, delay);
    }
  });

  // Set cookie so next visit within 10 min skips intro
  if (!skipIntro) {
    var d = new Date();
    d.setTime(d.getTime() + 10 * 60 * 1000);
    document.cookie = 'intro_done=1; expires=' + d.toUTCString() + '; path=/';
  }

  // Taskbar clock
  (function updateClock() {
    var now = new Date();
    var h = now.getHours().toString().padStart(2, '0');
    var m = now.getMinutes().toString().padStart(2, '0');
    var el = document.getElementById('taskbar-clock');
    if (el) el.textContent = h + ':' + m;
    setTimeout(updateClock, 30000);
  })();
})();
    </script>

    <% if (theme.math.enable && page.mathjax) { %>
        <script>
            window.MathJax = {
                tex: { inlineMath: [['$', '$'], ["\\(", "\\)"]], displayMath: [ ['$$','$$'], ["\\[","\\]"] ], processEscapes: true },
                options: { skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code'] }
            };
        </script>
        <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js" id="MathJax-script" async></script>
    <% } %>
</body>
</html>
