<!-- PC-98 Window: Spending Records -->
<div class="card pc98-window">
    <div class="pc98-titlebar">
        <span class="title-text"><%= page.title %></span>
        <span>_ &#9744; &#10005;</span>
    </div>
    <div class="pc98-menubar">
        <span class="menu-item"><span class="underline">F</span>ile</span>
        <span class="menu-item"><span class="underline">E</span>dit</span>
        <span class="menu-item"><span class="underline">V</span>iew</span>
        <span class="menu-item"><span class="underline">H</span>elp</span>
    </div>
    <div class="pc98-window-body" style="padding:16px;">
        <style>
          .spending-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 12px;
            margin-top: 16px;
          }
          .spending-card {
            background: #f7f2e7;
            border-top: solid 1px #606060;
            border-left: solid 1px #606060;
            border-bottom: solid 1px #101010;
            border-right: solid 1px #101010;
            box-shadow: 3px 3px 0 rgba(0,0,0,0.5);
            padding: 16px;
          }
          .spending-card .item-name {
            font-size: 1.1em;
            font-weight: 600;
            margin-bottom: 6px;
            color: #2849a2;
            font-family: "Roboto", "Segoe UI", sans-serif;
          }
          .spending-card .item-category {
            display: inline-block;
            font-size: 0.8em;
            padding: 2px 8px;
            background: #2849a2;
            color: #f9f9f9;
            margin-bottom: 12px;
            font-family: "Consolas", monospace;
          }
          .spending-card .item-detail {
            font-size: 0.9em;
            color: #222;
            line-height: 1.8;
            font-family: "Consolas", "MS Gothic", monospace;
          }
          .spending-card .item-detail .value {
            font-weight: 700;
            color: #000;
          }
          .spending-card .item-detail .per-day {
            font-size: 1.2em;
            color: #2849a2;
            font-weight: 700;
          }
          .spending-summary {
            background: #000;
            border: solid 1px #101010;
            padding: 16px 20px;
            margin-bottom: 16px;
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 16px;
            text-align: center;
          }
          .spending-summary .stat {
            flex: 1;
            min-width: 100px;
          }
          .spending-summary .stat-value {
            font-size: 1.4em;
            font-weight: 700;
            color: #e8c367;
            display: block;
            font-family: "Consolas", "MS Gothic", monospace;
          }
          .spending-summary .stat-label {
            font-size: 0.8em;
            color: #aaa;
            margin-top: 4px;
            display: block;
          }
        </style>

        <div class="spending-summary">
          <div class="stat">
            <span class="stat-value" id="totalSpent">--</span>
            <span class="stat-label">总消费</span>
          </div>
          <div class="stat">
            <span class="stat-value" id="totalPerDay">--</span>
            <span class="stat-label">全部日均摊销</span>
          </div>
          <div class="stat">
            <span class="stat-value" id="itemCount">--</span>
            <span class="stat-label">记录数</span>
          </div>
        </div>

        <div class="spending-grid" id="spendingGrid"></div>

        <script>
          var spendingData = <%- JSON.stringify(site.data.spending) %>;

          function calcDays(fromDate) {
            var from = new Date(fromDate);
            var today = new Date();
            var diff = today - from;
            return Math.max(1, Math.floor(diff / (1000 * 60 * 60 * 24)));
          }

          function renderSpending() {
            var sorted = spendingData.slice().sort(function(a, b) {
              return new Date(b.date) - new Date(a.date);
            });
            var grid = document.getElementById('spendingGrid');

            var totalSpent = 0;
            var totalPerDay = 0;

            sorted.forEach(function(item) {
              var days = calcDays(item.date);
              var perDay = item.price / days;
              totalSpent += item.price;
              totalPerDay += perDay;

              var card = document.createElement('div');
              card.className = 'spending-card';
              var cat = item.category || '其他';
              card.innerHTML =
                '<div class="item-name">' + escapeHtml(item.name) + '</div>' +
                '<span class="item-category">' + escapeHtml(cat) + '</span>' +
                '<div class="item-detail">' +
                  '<div>购买日期：' + item.date + '（已过 <span class="value">' + days + '</span> 天）</div>' +
                  '<div>价格：<span class="value">¥' + item.price.toLocaleString() + '</span></div>' +
                  '<div>日均：<span class="per-day">¥' + perDay.toFixed(2) + '</span></div>' +
                '</div>';
              grid.appendChild(card);
            });

            document.getElementById('totalSpent').textContent = '¥' + totalSpent.toLocaleString();
            document.getElementById('totalPerDay').textContent = '¥' + totalPerDay.toFixed(2);
            document.getElementById('itemCount').textContent = spendingData.length;
          }

          function escapeHtml(str) {
            var div = document.createElement('div');
            div.textContent = str;
            return div.innerHTML;
          }

          renderSpending();
        </script>
    </div>
</div>
