<!-- PC-98 Window: Archives -->
<div class="desktop-window win-archives draggable-element" style="top:50px;left:150px;width:520px;max-height:75vh;">
<div class="card pc98-window" style="height:100%;display:flex;flex-direction:column;">
    <div class="pc98-titlebar">
        <span class="title-text">Archives</span>
        <span>_ &#9744; &#10005;</span>
    </div>
    <div class="pc98-menubar">
        <span class="menu-item"><span class="underline">F</span>ile</span>
        <span class="menu-item"><span class="underline">E</span>dit</span>
        <span class="menu-item"><span class="underline">V</span>iew</span>
        <span class="menu-item"><span class="underline">H</span>elp</span>
    </div>
    <div class="pc98-window-body undraggable-element" style="flex:1;overflow-y:auto;padding:8px;">
        <section class="archive-container">
            <% var lastYear; %>
            <% page.posts.each(function(post, index) { %>
                <% var currentYear=post.date.year(); %>
                <% if (lastYear !==currentYear) { %>
                    <% if (lastYear !==undefined) { %>
                            </div>
                        </div>
                    <% } %>
                    <% lastYear=currentYear; %>
                    <div class="card year-group">
                        <div class="year-header">
                            <%= currentYear %>
                        </div>
                        <div class="archive-list">
                <% } %>
                <div class="archive-item">
                    <span class="archive-date">
                        <%= date(post.date, "MM-DD" ) %>
                    </span>
                    <a class="archive-title" href="<%- url_for(post.path) %>">
                        <%= post.title || 'Untitled' %>
                    </a>
                </div>
            <% }) %>
            <% if (page.posts.length> 0) { %>
                    </div>
                </div>
            <% } %>
        </section>

        <nav class="page-nav">
            <%- paginator({ prev_text: '<' , next_text: '>' }) %>
        </nav>
    </div>
</div>
</div>
