<!-- PC-98 Window: Article List -->
<div class="card pc98-window">
    <div class="pc98-titlebar">
        <span class="title-text">Posts</span>
        <span>_ &#9744; &#10005;</span>
    </div>
    <div class="pc98-menubar">
        <span class="menu-item"><span class="underline">F</span>ile</span>
        <span class="menu-item"><span class="underline">E</span>dit</span>
        <span class="menu-item"><span class="underline">V</span>iew</span>
        <span class="menu-item"><span class="underline">H</span>elp</span>
    </div>
    <div class="pc98-window-body" style="padding:8px;">
        <section class="post-list">
            <% page.posts.forEach(function(post){ %>
            <article class="card post-item">
                <% if (post.cover) { %>
                    <div class="post-cover">
                        <a href="<%- url_for(post.path) %>">
                            <img src="<%- url_for(post.cover) %>" alt="<%= post.title %>">
                        </a>
                    </div>
                <% } %>
                <div class="post-info">
                    <span class="post-title">
                        <a href="<%- url_for(post.path) %>" style="color:inherit;text-decoration:none;">
                            <%= post.title %>
                        </a>
                    </span>
                    <div class="post-meta">
                        <%= date(post.date, 'YYYY-MM-DD' ) %>
                    </div>
                    <div class="post-excerpt">
                        <%- truncate(strip_html(post.excerpt || post.content), {length: 150, omission: '...'}) %>
                    </div>
                    <a href="<%- url_for(post.path) %>" class="button rm-link">
                        <span class="read-more">Read More</span>
                    </a>
                </div>
            </article>
            <% }) %>
        </section>

        <nav class="page-nav">
            <%- paginator({ prev_text: '<' , next_text: '>' }) %>
        </nav>
    </div>
</div>
